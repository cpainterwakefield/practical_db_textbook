                                    C09
                                </cell>
            <cell>
                                    Ms. Larsen
                                </cell>
          </row>
          <row>
            <cell>
                                    Physics
                                </cell>
            <cell>
                                    11:00
                                </cell>
            <cell>
                                    C06
                                </cell>
            <cell>
                                    Ms. Musa
                                </cell>
          </row>
          <row>
            <cell>
                                    Chemistry
                                </cell>
            <cell>
                                    13:00
                                </cell>
            <cell>
                                    C17
                                </cell>
            <cell>
                                    Ms. Musa
                                </cell>
          </row>
