                                genre
                            </cell>
          <cell>
                                author_birth
                            </cell>
          <cell>
                                author_death
                            </cell>
          <cell>
                                section
                            </cell>
        </row>
        <row>
          <cell>
                                Ralph Ellison
                            </cell>
          <cell>
