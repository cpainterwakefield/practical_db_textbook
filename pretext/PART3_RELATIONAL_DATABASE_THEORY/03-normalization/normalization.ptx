          <row>
            <cell>
                                    Ms. Tan
                                </cell>
            <cell>
                                    A11
                                </cell>
            <cell>
                                    Humanities
                                </cell>
          </row>
          <row>
            <cell>
                                    Ms. Larsen
                                </cell>
            <cell>
                                    A05
                                </cell>
            <cell>
                                    Humanities
