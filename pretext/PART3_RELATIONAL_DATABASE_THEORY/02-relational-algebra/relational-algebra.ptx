                                </cell>
            <cell>
                                    Ralph Ellison
                                </cell>
            <cell>
                                    1914-03-01
                                </cell>
            <cell>
                                    1994-04-16
                                </cell>
          </row>
          <row>
            <cell>
                                    2
                                </cell>
            <cell>
                                    1
                                </cell>
            <cell>
              <em>Invisible Man</em>
            </cell>
            <cell>
                                    1952
                                </cell>
            <cell>
                                    2
                                </cell>
            <cell>
                                    Jhumpa Lahiri
                                </cell>
            <cell>
                                    1967-07-11
                                </cell>
            <cell>
                                </cell>
          </row>
          <row>
            <cell>
                                    2
                                </cell>
            <cell>
                                    1
                                </cell>
            <cell>
              <em>Invisible Man</em>
            </cell>
            <cell>
                                    1952
                                </cell>
            <cell>
                                    3
                                </cell>
            <cell>
                                    Isabel Allende
                                </cell>
            <cell>
