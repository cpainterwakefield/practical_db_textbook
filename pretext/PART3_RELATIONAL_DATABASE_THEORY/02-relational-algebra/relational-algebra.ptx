                                </cell>
            <cell>
                                </cell>
          </row>
          <row>
            <cell>
                                    1
                                </cell>
            <cell>
                                    3
                                </cell>
            <cell>
              <em>The House of the Spirits</em>
            </cell>
            <cell>
                                    1982
                                </cell>
            <cell>
                                    3
                                </cell>
            <cell>
                                    Isabel Allende
                                </cell>
            <cell>
                                    1942-08-02
                                </cell>
            <cell>
                                </cell>
          </row>
          <row>
            <cell>
                                    2
                                </cell>
            <cell>
                                    1
                                </cell>
            <cell>
              <em>Invisible Man</em>
            </cell>
            <cell>
                                    1952
                                </cell>
            <cell>
